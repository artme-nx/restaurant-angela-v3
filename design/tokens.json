{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "paper": {
        "100": { "$value": "#FBF6EA", "$type": "color" },
        "200": { "$value": "#F3EAD3", "$type": "color" },
        "300": { "$value": "#E6D8B8", "$type": "color" },
        "400": { "$value": "#D3C09A", "$type": "color" }
      },
      "ink": {
        "950": { "$value": "#241A10", "$type": "color" },
        "800": { "$value": "#3B2C1C", "$type": "color" },
        "500": { "$value": "#6B5B44", "$type": "color" }
      },
      "sage": {
        "700": { "$value": "#47563A", "$type": "color" },
        "500": { "$value": "#6C7C52", "$type": "color" },
        "300": { "$value": "#9FAE81", "$type": "color" }
      },
      "bloom": {
        "600": { "$value": "#A64B3D", "$type": "color" },
        "400": { "$value": "#C97862", "$type": "color" },
        "200": { "$value": "#E4B49B", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-cormorant), 'Cormorant Garamond', Georgia, serif", "$type": "fontFamily" },
      "body": { "$value": "var(--font-lora), 'Lora', Georgia, serif", "$type": "fontFamily" },
      "script": { "$value": "var(--font-caveat), 'Caveat', cursive", "$type": "fontFamily" },
      "label": { "$value": "var(--font-courier), 'Courier Prime', 'Courier New', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.2s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "0em", "$type": "dimension" },
      "label": { "$value": "0.22em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.paper.200}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "card": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "muted": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "border": { "$value": "{primitive.color.paper.400}", "$type": "color" },
    "ring": { "$value": "{primitive.color.bloom.400}", "$type": "color" },
    "radius": { "$value": "0.15rem", "$type": "dimension" },
    "moss": { "$value": "{primitive.color.sage.700}", "$type": "color" },
    "moss-soft": { "$value": "{primitive.color.sage.500}", "$type": "color" },
    "moss-pale": { "$value": "{primitive.color.sage.300}", "$type": "color" },
    "terracotta": { "$value": "{primitive.color.bloom.600}", "$type": "color" },
    "terracotta-soft": { "$value": "{primitive.color.bloom.400}", "$type": "color" },
    "terracotta-pale": { "$value": "{primitive.color.bloom.200}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.paper.400}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.body}", "$type": "fontFamily" },
    "type-script": { "$value": "{primitive.font.script}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.label}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "specimen": {
      "card-bg": { "$value": "{primitive.color.paper.100}", "$type": "color" },
      "card-border": { "$value": "{primitive.color.paper.400}", "$type": "color" },
      "pin-color": { "$value": "{primitive.color.bloom.600}", "$type": "color" },
      "tape-bg": { "$value": "rgba(230, 216, 184, 0.65)", "$type": "color" }
    },
    "hero": {
      "vignette": {
        "$value": "radial-gradient(ellipse 90% 60% at 50% 0%, rgba(36, 26, 16, 0.08), transparent 60%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.bloom.600}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.paper.100}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.ink.950}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.paper.100}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.sage.700}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.bloom.600}", "$type": "color" }
    }
  }
}
